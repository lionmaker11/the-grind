{
  "rewrites": [
    { "source": "/today.json", "destination": "/public/today.json" }
  ],
  "headers": [
    {
      "source": "/public/today.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    }
  ]
}
