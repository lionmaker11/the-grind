# Copy this file to /v2/.env.local (gitignored) and fill in the values.

# Same value as the CHIEF_AUTH_TOKEN env var in Vercel (Preview + Production).
# Sent as the X-Chief-Token header on every /api/* call. Mutating endpoints
# reject requests without it.
VITE_CHIEF_AUTH_TOKEN=

# Dev-only. URL of a live Vercel preview deployment that has the backend
# env vars configured. vite.config.js proxies /api/* to this host during
# `npm run dev`. Pick the current preview URL for the v2-build branch, or
# fall back to the production URL if it has working env vars.
# Default if unset: https://the-grind.vercel.app
VITE_API_PROXY_TARGET=
